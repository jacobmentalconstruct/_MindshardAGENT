# ============================================================
# MindshardAGENT - Git Ignore
# Local runtime state, builder tooling, caches, and machine-
# specific artifacts that should not be committed.
# ============================================================

# Python bytecode / caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/
.coverage
.coverage.*
htmlcov/

# Virtual environments / packaging
.venv/
venv/
ENV/
env/
.conda/
.condarc
pip-wheel-metadata/
build/
dist/
*.egg-info/
.eggs/
pip-log.txt

# IDE / editor / local agent surfaces
.vscode/
.idea/
*.code-workspace
.claude/
.codex/
.cursor/
.dev-tools/

# OS junk
.DS_Store
Thumbs.db
Desktop.ini

# Logs / temp / scratch
*.log
*.tmp
*.temp
*.swp
*~
*.pid
*.out
*.bak
*.orig
.cache/
_logs/
_sandbox/

# App persistence / generated data
_db/
*.db
*.sqlite
*.sqlite3
*.db-journal
*.sqlite-journal
*.wal
*.shm
*.zip

# JSONL / generated session artifacts
*.jsonl
memory_archive_*.jsonl
working_memory*.jsonl
session_*.jsonl

# Local config / secrets / machine state
.env
.env.*
*.env
.direnv/
.python-version
secrets.json
config.local.json
app_config.json
app_config.json.tmp
*.local.json
*.local.toml
*.local.yaml
*.local.yml
*.local.ini
*.secret
*.secrets
local_settings/
private/

# Local docs / builder continuity / private helper docs
_docs/
_randomDOCS/

# Prompt/versioning and runtime sidecars
.mindshard/
.prompt-versioning/

# Vector / RAG stores
knowledge_base/
chroma/
chromadb/
vector_store/
vectors/
*.faiss
*.index

# Jupyter / notebook state
.ipynb_checkpoints/

# Optional local reports / dumps
*_project_map.txt
*_filedump.txt
*_folder_tree.txt
reports/
output/

# Local diagnostic outputs
_utils/agent_diagnostic_lab/_logs/
_utils/agent_diagnostic_lab/outputs/
