{
  "manifest_version": "1.0",
  "name": "app-journal",
  "description": "Standalone SQLite-backed journal package with Tkinter UI and MCP tools for project notes.",
  "portable_project": true,
  "isolated_folder": true,
  "status": "active",
  "recommended_folders": [
    "tools",
    "lib",
    "ui",
    "jobs",
    "artifacts",
    "templates",
    "drop-bin"
  ],
  "mechanical_contract": {
    "cli_commands": [
      "metadata",
      "run --input-json '{...}'",
      "run --input-file path/to/input.json"
    ],
    "mcp_transport": "stdio",
    "result_envelope_keys": [
      "status",
      "tool",
      "input",
      "result"
    ]
  },
  "vendoring": {
    "zip_safe_as_folder": true,
    "preferred_mode": "whole_folder",
    "consumer_rule": "Use the whole package from .dev-tools rather than copying internals into app code.",
    "verification": "python _app-journal/smoke_test.py"
  },
  "mcp_entrypoint": "mcp_server.py",
  "ui_entrypoint": "launch_ui.py",
  "self_test_entrypoint": "smoke_test.py",
  "tools": [
    {
      "tool_name": "journal_init",
      "script": "tools/journal_init.py",
      "mcp_name": "journal_init",
      "category": "bootstrap"
    },
    {
      "tool_name": "journal_manifest",
      "script": "tools/journal_manifest.py",
      "mcp_name": "journal_manifest",
      "category": "introspection"
    },
    {
      "tool_name": "journal_write",
      "script": "tools/journal_write.py",
      "mcp_name": "journal_write",
      "category": "write"
    },
    {
      "tool_name": "journal_query",
      "script": "tools/journal_query.py",
      "mcp_name": "journal_query",
      "category": "query"
    },
    {
      "tool_name": "journal_export",
      "script": "tools/journal_export.py",
      "mcp_name": "journal_export",
      "category": "export"
    }
  ]
}
