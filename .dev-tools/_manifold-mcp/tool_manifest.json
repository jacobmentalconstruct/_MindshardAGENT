{
  "manifest_version": "1.0",
  "name": "manifold-mcp",
  "description": "Standalone reversible text-hypergraph-text MCP tool suite built around evidence bags.",
  "portable_project": true,
  "isolated_folder": true,
  "status": "active",
  "recommended_folders": [
    "tools",
    "lib",
    "sdk",
    "jobs",
    "artifacts",
    "templates",
    "drop-bin"
  ],
  "mechanical_contract": {
    "cli_commands": [
      "metadata",
      "run --input-json '{...}'",
      "run --input-file path/to/input.json"
    ],
    "mcp_transport": "stdio",
    "result_envelope_keys": [
      "status",
      "tool",
      "input",
      "result"
    ]
  },
  "vendoring": {
    "zip_safe_as_folder": true,
    "preferred_mode": "whole_folder",
    "consumer_rule": "Import or call from .dev-tools rather than copying internals into an app.",
    "verification": "python _manifold-mcp/smoke_test.py"
  },
  "mcp_entrypoint": "mcp_server.py",
  "self_test_entrypoint": "smoke_test.py",
  "sdk": {
    "entrypoint": "sdk/evidence_package.py",
    "exports": [
      "EvidencePackage"
    ]
  },
  "tools": [
    {
      "tool_name": "manifold_ingest",
      "script": "tools/manifold_ingest.py",
      "mcp_name": "manifold_ingest",
      "category": "ingest"
    },
    {
      "tool_name": "manifold_query",
      "script": "tools/manifold_query.py",
      "mcp_name": "manifold_query",
      "category": "query"
    },
    {
      "tool_name": "manifold_extract",
      "script": "tools/manifold_extract.py",
      "mcp_name": "manifold_extract",
      "category": "extract"
    },
    {
      "tool_name": "bag_inspect",
      "script": "tools/bag_inspect.py",
      "mcp_name": "bag_inspect",
      "category": "inspect"
    },
    {
      "tool_name": "bag_navigate",
      "script": "tools/bag_navigate.py",
      "mcp_name": "bag_navigate",
      "category": "inspect"
    }
  ]
}
