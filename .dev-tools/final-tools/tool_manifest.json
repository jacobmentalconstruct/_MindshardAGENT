{
  "manifest_version": "1.0",
  "name": "final-tools",
  "description": "Unified headless tools for AI agents working in local folders.",
  "portable_project": true,
  "recommended_folders": [
    "tools",
    "jobs",
    "artifacts",
    "drop-bin"
  ],
  "mechanical_contract": {
    "cli_commands": [
      "metadata",
      "run --input-json '{...}'",
      "run --input-file path/to/input.json"
    ],
    "result_envelope_keys": [
      "status",
      "tool",
      "input",
      "result"
    ]
  },
  "mcp_entrypoint": "mcp_server.py",
  "self_test_entrypoint": "smoke_test.py",
  "builder_guide": "BUILDER_GUIDE.md",
  "vendoring_guide": "VENDORING.md",
  "tools": [
    {
      "tool_name": "workspace_audit",
      "script": "tools/workspace_audit.py",
      "category": "workspace"
    },
    {
      "tool_name": "data_shape_inspector",
      "script": "tools/data_shape_inspector.py",
      "category": "data"
    },
    {
      "tool_name": "structured_patch",
      "script": "tools/structured_patcher.py",
      "category": "editing"
    },
    {
      "tool_name": "python_risk_scan",
      "script": "tools/python_risk_scan.py",
      "category": "analysis"
    },
    {
      "tool_name": "tk_ui_map",
      "script": "tools/tk_ui_map.py",
      "category": "ui"
    },
    {
      "tool_name": "tk_ui_thread_audit",
      "script": "tools/tk_ui_thread_audit.py",
      "category": "ui"
    },
    {
      "tool_name": "tk_ui_event_map",
      "script": "tools/tk_ui_event_map.py",
      "category": "ui"
    },
    {
      "tool_name": "tk_ui_layout_audit",
      "script": "tools/tk_ui_layout_audit.py",
      "category": "ui"
    },
    {
      "tool_name": "tk_ui_test_scaffold",
      "script": "tools/tk_ui_test_scaffold.py",
      "category": "ui"
    }
  ]
}
