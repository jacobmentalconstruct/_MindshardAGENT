{
  "manifest_version": "1.0",
  "name": "ollama-prompt-lab",
  "description": "Isolated local prompt-evaluation and agent-behavior workbench for Ollama models.",
  "portable_project": true,
  "isolated_folder": true,
  "status": "active",
  "recommended_folders": [
    "tools",
    "jobs",
    "artifacts",
    "templates",
    "sessions",
    "drop-bin"
  ],
  "mechanical_contract": {
    "cli_commands": [
      "metadata",
      "run --input-json '{...}'",
      "run --input-file path/to/input.json"
    ],
    "mcp_transport": "stdio",
    "result_envelope_keys": [
      "status",
      "tool",
      "input",
      "result"
    ]
  },
  "mcp_entrypoint": "mcp_server.py",
  "self_test_entrypoint": "smoke_test.py",
  "tools": [
    {
      "tool_name": "ollama_prompt_lab",
      "script": "tools/ollama_prompt_lab.py",
      "mcp_name": "ollama_prompt_lab",
      "category": "evaluation"
    }
  ],
  "planned_tools": [
    {
      "tool_name": "prompt_case_builder",
      "category": "evaluation"
    },
    {
      "tool_name": "prompt_rubric_judge",
      "category": "evaluation"
    },
    {
      "tool_name": "prompt_diff_report",
      "category": "reporting"
    },
    {
      "tool_name": "agent_interview",
      "category": "evaluation"
    }
  ]
}
